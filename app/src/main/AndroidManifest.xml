<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Microfono per il riconoscimento vocale -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Rete per le chiamate al provider LLM -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Scrittura/lettura eventi tramite il Calendar Provider di sistema -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.WRITE_CALENDAR" />

    <!-- Necessario su Android 11+ per interrogare i servizi di riconoscimento vocale -->
    <queries>
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
    </queries>

    <!-- usesCleartextTraffic: necessario per raggiungere un server Ollama
         sulla rete locale via http:// (Gemini resta comunque su https) -->
    <application
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:theme="@style/Theme.FlowerNotes"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Testo condiviso da altre app (es. un messaggio) → evento -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <!-- Quick Settings Tile: apre l'app in modalità ascolto -->
        <service
            android:name=".tile.VoiceTileService"
            android:exported="true"
            android:icon="@drawable/ic_tile_mic"
            android:label="@string/tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>
    </application>
</manifest>
